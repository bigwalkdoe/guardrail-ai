# Guardrail AI Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=production
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# =============================================================================
# API Configuration
# =============================================================================
API_PORT=8000
METRICS_PORT=8888
FRONTEND_PORT=3000

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
POSTGRES_DB=guardrail
POSTGRES_USER=guardrail_user
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_PORT=55432
DB_POOL_SIZE=40
DB_MAX_OVERFLOW=60

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_PORT=6379
CACHE_TTL=300

# =============================================================================
# Neo4j Configuration
# =============================================================================
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-secure-neo4j-password
NEO4J_PORT=7474
NEO4J_BOLT_PORT=7687

# =============================================================================
# RabbitMQ Configuration
# =============================================================================
RABBITMQ_USER=guardrail_user
RABBITMQ_PASSWORD=your-secure-rabbitmq-password
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# =============================================================================
# Monitoring Configuration
# =============================================================================
LOG_LEVEL=INFO
SENTRY_DSN=  # Optional: Sentry DSN for error tracking

# =============================================================================
# Grafana Configuration
# =============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-secure-grafana-password
GRAFANA_PORT=3002

# =============================================================================
# Prometheus Configuration
# =============================================================================
PROMETHEUS_PORT=9091

# =============================================================================
# Frontend Configuration
# =============================================================================
VITE_BACKEND_URL=http://localhost:8000

# =============================================================================
# Celery Worker Configuration
# =============================================================================
CELERY_WORKER_CONCURRENCY=8
CELERY_MAX_TASKS_PER_CHILD=500

# =============================================================================
# Encryption
# =============================================================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# =============================================================================
# Security Settings
# =============================================================================
# Add any additional security-related environment variables here
# For example: JWT secrets, API keys, etc.
